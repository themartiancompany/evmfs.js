{
  "name":
    "evmfs",
  "version":
    "0.0.9",
  "description":
    "Multi-level distributed, network-independent, cross-network, uncensorable, undeletable, permissionless file system running on Ethereum Virtual Machine-compatible networks.",
  "funding":
    { "type":
        "patreon",
      "url":
        "https://patreon.com/tallero"
  },
  "files": [
    "AUTHORS.rst",
    "COPYING",
    "README.md",
    "evmfs",
    "contracts",
    "eslint.config.mjs",
    "man",
    "lib",
    "libevmfs",
    "libevmfs.webpack.config.cjs",
    "package.json",
    "webpack.config.cjs"
  ],
  "man": [
    "./man/evmfs.js.ccget.1",
    "./man/evmfs.js.check.1",
    "./man/evmfs.js.get.1",
    "./man/evmfs.js.index.1",
    "./man/evmfs.js.lengthlock.1",
    "./man/evmfs.js.lock.1",
    "./man/evmfs.js.publish.1",
    "./man/evmfs.js.publish.bulk.1",
    "./man/evmfs.js.verify.1"
  ],
  "bin": {
      "evmfs":
        "evmfs",
      "evmfs.js":
        "evmfs",
      "evmfs.js.ccget":
        "lib/evmfs.js.ccget",
      "evmfs.js.check":
        "lib/evmfs.js.check",
      "evmfs.js.get":
        "lib/evmfs.js.get",
      "evmfs.js.index":
        "lib/evmfs.js.index",
      "evmfs.js.lengthlock":
        "lib/evmfs.js.lengthlock",
      "evmfs.js.lock":
        "lib/evmfs.js.lock",
      "evmfs.js.publish":
        "lib/evmfs.js.publish",
      "evmfs.js.publish.bulk":
        "lib/evmfs.js.publish.bulk",
      "evmfs.js.verify":
        "lib/evmfs.js.verify" },
  "keywords": [
    "dogeos",
    "opfs",
    "evmfs",
    "fs",
    "hip",
    "libevm",
    "crash-js",
    "themartiancompany",
    "ur"
  ],
  "homepage":
    "https://github.com/themartiancompany/evmfs",
  "bugs": {
    "url":
      "https://github.com/themartiancompany/evmfs/issues"
  },
  "repository": {
    "type":
      "git",
    "url":
      "git+https://github.com/themartiancompany/evmfs.js.git"
  },
  "license":
    "AGPL-3.0-or-later",
  "author":
    { "name":
        "Pellegrino Prevete",
      "email":
        "pellegrinoprevete@gmail.com",
      "url":
        "https://github.com/tallero"
  },
  "devDependencies": {
    "crash-js-webpack":
      "^0.0.41",
    "eslint":
      "^10.3.0",
    "globals":
      "^17.3.0",
    "@eslint/js":
      "^10.0.1",
    "webpack":
      "^5.102.1",
    "webpack-cli":
      "^6.0.1"
  },
  "dependencies": {
    "crash-js":
      "0.11.111111111111",
    "encoding-tools":
      "0.0.14",
    "ethereum-data":
      "0.0.4",
    "evm-wallet.js":
      "0.0.72",
    "libevm":
      "0.0.32",
    "evmfs-contracts":
      "0.0.2",
    "yargs":
      "18.0.0"
  },
  "overrides": {
    "evm-wallet":
      "npm:evm-wallet.js@0.0.72",
    "libevm":
      "0.0.32"
  },
  "type":
    "commonjs",
  "main":
    "libevmfs",
  "scripts":
    { "build":
        "npm run lint && npm run build-lib && npm build-bin",
      "build-lib":
        "npx webpack --mode 'production' --config 'libevmfs.lwebpack.config.cjs' --stats-error-details && mv 'libevmfs.js' 'dist/libevmfs'",
      "build-bin":
        "npx webpack --mode 'production' --config 'webpack.config.cjs' --stats-error-details && mv 'evmfs.js' 'dist/evmfs'",
      "lint":
        "npx eslint .",
      "start":
        "npx safely-serve 'dist/evmfs'",
      "test":
        "echo \"Error: no test specified\" && exit 1" },
  "yargs": {
    "parse-numbers":
      false,
    "parse-positional-numbers":
      false
  }
}
